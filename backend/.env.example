# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
DATABASE_URL=./data/minijira.db

# Sessions (8h = 28800000 ms)
SESSION_SECRET=
SESSION_MAX_AGE=28800000

# OAuth provider: "google" | "azure"
OAUTH_PROVIDER=google
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Google Workspace OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_HOSTED_DOMAIN=

# Azure AD OAuth (solo si OAUTH_PROVIDER=azure)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Mini Jira <noreply@yourcompany.com>"

# Metrics cache
METRICS_REFRESH_INTERVAL_MS=900000
